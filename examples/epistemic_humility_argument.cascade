    },
    {
      "id": "file-001-c",
      "pyramid_id": "example-001",
      "name": "Synthesis",
      "score_aggregate": 71,
      "blocks": [
        {
          "id": "block-001-6",
          "file_id": "file-001-c",
          "pyramid_id": "example-001",
          "title": "Synthesis — Domain-Sensitive Humility",
          "content": "Epistemic humility is necessary for rationality, but it is domain-sensitive: it applies to empirical and normative claims, where evidence can always revise; it does not apply to formal truths, where the question of revision does not arise in the same sense. The pragmatist objection reveals not a refutation but a constraint — epistemic humility must be distinguished from action paralysis. The rational agent holds beliefs provisionally while acting decisively.",
          "score_aggregate": 74,
          "framework_refs": ["cascade", "aura"],
          "position": 0,
          "pinned": true,
          "tags": ["synthesis"],
          "source_block_ids": ["block-001-1", "block-001-2", "block-001-3", "block-001-4", "block-001-5"],
          "layers": [
            { "layer": "AXIOM",       "framework_score": 80, "sovereign_score": null, "notes": "" },
            { "layer": "FOUNDATION",  "framework_score": 77, "sovereign_score": null, "notes": "" },
            { "layer": "STRUCTURE",   "framework_score": 74, "sovereign_score": null, "notes": "" },
            { "layer": "COHERENCE",   "framework_score": 73, "sovereign_score": null, "notes": "" },
            { "layer": "RESONANCE",   "framework_score": 72, "sovereign_score": null, "notes": "" },
            { "layer": "TENSION",     "framework_score": 68, "sovereign_score": null, "notes": "" },
            { "layer": "CONTESTED",   "framework_score": 64, "sovereign_score": null, "notes": "" },
            { "layer": "SPECULATIVE", "framework_score": 60, "sovereign_score": null, "notes": "" },
            { "layer": "FRONTIER",    "framework_score": 55, "sovereign_score": null, "notes": "Open question: does epistemic humility require a theory of mind capable of modelling its own errors, or can it be formalised without consciousness?" }
