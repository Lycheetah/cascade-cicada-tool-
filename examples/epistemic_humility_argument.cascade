    {
      "id": "file-001-b",
      "pyramid_id": "example-001",
      "name": "Objections",
      "score_aggregate": 58,
      "blocks": [
        {
          "id": "block-001-4",
          "file_id": "file-001-b",
          "pyramid_id": "example-001",
          "title": "Objection — Dogmatic Rationalism",
          "content": "A Cartesian rationalist might argue that some truths (logical axioms, mathematical necessities) are known with certainty and that humility about them is not epistemic virtue but epistemic confusion. 2+2=4 does not require hedging; humility here would be performative rather than functional.",
          "score_aggregate": 62,
          "framework_refs": ["cascade"],
          "position": 0,
          "pinned": false,
          "tags": ["objection", "contested"],
          "layers": [
            { "layer": "AXIOM",       "framework_score": 70, "sovereign_score": null, "notes": "" },
            { "layer": "FOUNDATION",  "framework_score": 65, "sovereign_score": null, "notes": "" },
            { "layer": "STRUCTURE",   "framework_score": 62, "sovereign_score": null, "notes": "" },
            { "layer": "COHERENCE",   "framework_score": 60, "sovereign_score": null, "notes": "" },
            { "layer": "RESONANCE",   "framework_score": 58, "sovereign_score": null, "notes": "" },
            { "layer": "TENSION",     "framework_score": 55, "sovereign_score": null, "notes": "This is a genuine tension — the argument may need to distinguish domain-specific certainty from general epistemic humility." },
            { "layer": "CONTESTED",   "framework_score": 50, "sovereign_score": null, "notes": "" },
            { "layer": "SPECULATIVE", "framework_score": 45, "sovereign_score": null, "notes": "" },
            { "layer": "FRONTIER",    "framework_score": 40, "sovereign_score": null, "notes": "" }
          ]
        },
        {
          "id": "block-001-5",
          "file_id": "file-001-b",
          "pyramid_id": "example-001",
          "title": "Objection — Action Requires Commitment",
          "content": "Pragmatists argue that deliberate action requires treating some beliefs as settled for practical purposes. Permanent epistemic humility can produce paralysis. Rationality in action contexts may require bracketing uncertainty, not foregrounding it.",
          "score_aggregate": 55,
          "framework_refs": ["cascade"],
          "position": 1,
          "pinned": false,
          "tags": ["objection", "pragmatism"],
          "layers": [
            { "layer": "AXIOM",       "framework_score": 65, "sovereign_score": null, "notes": "" },
            { "layer": "FOUNDATION",  "framework_score": 60, "sovereign_score": null, "notes": "" },
            { "layer": "STRUCTURE",   "framework_score": 57, "sovereign_score": null, "notes": "" },
            { "layer": "COHERENCE",   "framework_score": 55, "sovereign_score": null, "notes": "" },
            { "layer": "RESONANCE",   "framework_score": 52, "sovereign_score": null, "notes": "" },
            { "layer": "TENSION",     "framework_score": 48, "sovereign_score": null, "notes": "" },
            { "layer": "CONTESTED",   "framework_score": 44, "sovereign_score": null, "notes": "" },
            { "layer": "SPECULATIVE", "framework_score": 40, "sovereign_score": null, "notes": "" },
            { "layer": "FRONTIER",    "framework_score": 35, "sovereign_score": null, "notes": "" }
          ]
        }
