{
  "name": "cascade-cicada-tool",
  "version": "0.3.0",
  "description": "CASCADE CICADA TOOL (TCCT) — Knowledge Operating System, Personal Pyramid Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "vite": "vite",
    "electron": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "set WIN_CSC_LINK=&& set CSC_LINK=&& set CSC_IDENTITY_AUTO_DISCOVERY=false&& vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "vite": "^5.1.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.lycheetah.tcct",
    "productName": "CASCADE CICADA TOOL",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "portable",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Education"
    }
  }
}
